# ── Scraper (user token approach) ────────────────────────────────────
# Get this from browser DevTools > Network tab > any discord.com/api request > Authorization header
DISCORD_USER_TOKEN=your_user_token_here

# ── Bot (optional, only if you have server admin access) ─────────────
DISCORD_BOT_TOKEN=

# ── Slack (optional -- leave empty to use dashboard only) ────────────
SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_HIGH_PRIORITY=

# ── Dashboard ────────────────────────────────────────────────────────
DASHBOARD_PORT=8099
